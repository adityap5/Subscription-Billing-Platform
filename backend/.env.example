# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/subscription-billing?retryWrites=true&w=majority

# JWT secret for signing access tokens — use a strong random string
JWT_SECRET=your-jwt-secret-here

# JWT token expiration (e.g., 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Razorpay API keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Razorpay webhook secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Resend API key for sending emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender email address/domain in Resend
RESEND_FROM_EMAIL=billing@yourdomain.com

# Frontend URL — used for CORS whitelist and email links
FRONTEND_URL=http://localhost:3000

# Backend server port
PORT=5000